rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: username (string), full_name (string), password_hash (string), role (enum), created_at (timestamp)
    //
    // Collection: incident_reports
    // Fields: tracking_number (string), type (string), incident_date (timestamp), location_text (string), 
    //         lat (number), lng (number), description (string), photo_path (string), status (enum), created_at (timestamp)
    //
    // Collection: bulletins
    // Fields: title (string), category (enum), body (string), photo_path (string), is_archived (bool), posted_by (string), created_at (timestamp)
    //
    // Collection: anonymous_tips
    // Fields: tip_id (string), concern_type (string), location_text (string), description (string), photo_path (string), is_flagged (bool), created_at (timestamp)
    //
    // Collection: hotlines
    // Fields: name (string), number (string), category (string), updated_at (timestamp)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['superadmin', 'staff'] ||
         (request.auth.token.email == "rcsreano@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
         (request.auth.token.email == "rcsreano@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'full_name', 'password_hash', 'role']) &&
             isValidString(data.username, 3, 50) &&
             isValidString(data.full_name, 2, 100) &&
             data.role in ['superadmin', 'staff'];
    }

    function isValidIncidentReport(data) {
      return data.keys().hasAll(['tracking_number', 'type', 'incident_date', 'location_text', 'lat', 'lng', 'description', 'status']) &&
             isValidString(data.tracking_number, 10, 20) &&
             isValidString(data.type, 2, 50) &&
             isValidString(data.location_text, 5, 255) &&
             data.lat is number && data.lng is number &&
             isValidString(data.description, 10, 2000) &&
             data.status in ['Received', 'Under Review', 'Resolved', 'Closed'];
    }

    function isValidBulletin(data) {
      return data.keys().hasAll(['title', 'category', 'body', 'posted_by']) &&
             isValidString(data.title, 5, 200) &&
             data.category in ['Wanted Person', 'Missing Person', 'Crime Advisory', 'Recovered Property', 'General Announcement'] &&
             isValidString(data.body, 10, 5000) &&
             data.posted_by is string;
    }

    function isValidTip(data) {
      return data.keys().hasAll(['tip_id', 'concern_type', 'location_text', 'description']) &&
             isValidString(data.tip_id, 5, 50) &&
             isValidString(data.concern_type, 2, 50) &&
             isValidString(data.location_text, 5, 255) &&
             isValidString(data.description, 10, 2000);
    }

    function isValidMapPoint(data) {
      return data.keys().hasAll(['lat', 'lng', 'incident_type', 'incident_date']) &&
             data.lat is number && data.lng is number &&
             isValidString(data.incident_type, 2, 50) &&
             isValidString(data.incident_date, 10, 20);
    }

    // Match Rules
    match /users/{userId} {
      allow read: if true; // Needed for server-side login without admin SDK
      allow create, update, delete: if false; // Protect users from public write
    }

    match /incident_reports/{reportId} {
      allow read: if true; 
      allow create: if true; // Allow public to report
      allow update: if true; // Needed for server-side updates
      allow delete: if false;
    }

    match /bulletins/{bulletinId} {
      allow read: if true;
      allow create, update: if true; // Needed for server-side updates
      allow delete: if false;
    }

    match /anonymous_tips/{tipId} {
      allow read: if true;
      allow create: if true; // Allow public to tip
      allow update: if true; // Needed for server-side updates
      allow delete: if false;
    }

    match /hotlines/{hotlineId} {
      allow read: if true;
      allow create, update: if true; // Needed for server-side updates
      allow delete: if false;
    }

    match /map_points/{pointId} {
      allow read: if true;
      allow create, update, delete: if true; // Needed for server-side updates
    }

    match /audit_logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /test/{docId} {
      allow read, write: if true; // For testing
    }
  }
}
