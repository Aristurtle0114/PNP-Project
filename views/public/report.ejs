<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-2xl overflow-hidden border border-gray-100 dark:border-slate-700">
        <!-- Form Header -->
        <div class="bg-pnp-blue p-10 text-white relative overflow-hidden">
            <div class="relative z-10">
                <h1 class="text-3xl font-black text-pnp-gold mb-2 uppercase tracking-tighter">File Incident Report</h1>
                <p class="text-blue-100 max-w-xl">Provide accurate details about the incident. Your report will be assigned a tracking number for follow-up.</p>
            </div>
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 -translate-y-1/2 translate-x-1/2 rounded-full"></div>
        </div>

        <form action="/report" method="POST" enctype="multipart/form-data" class="p-10 space-y-12" id="reportForm">
            <!-- Section 1: Incident Type & Date -->
            <div class="space-y-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="w-10 h-10 bg-pnp-blue text-white rounded-xl flex items-center justify-center font-black">1</div>
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white uppercase tracking-tight">Incident Information</h2>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label for="type" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Type of Incident <span class="text-red-500">*</span></label>
                        <select name="type" id="type" required class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition font-bold text-gray-700 dark:text-gray-300">
                            <option value="" disabled selected>Select Incident Type</option>
                            <option value="Theft">Theft</option>
                            <option value="Vandalism">Vandalism</option>
                            <option value="Assault">Assault</option>
                            <option value="Suspicious Activity">Suspicious Activity</option>
                            <option value="Robbery">Robbery</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label for="incident_date" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Date & Time of Incident <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="incident_date" id="incident_date" required class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition font-bold text-gray-700 dark:text-gray-300">
                    </div>
                </div>
            </div>

            <!-- Section 2: Location -->
            <div class="space-y-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="w-10 h-10 bg-pnp-blue text-white rounded-xl flex items-center justify-center font-black">2</div>
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white uppercase tracking-tight">Location Details</h2>
                </div>

                <div class="space-y-6">
                    <div class="space-y-2">
                        <label for="location_text" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Specific Location / Barangay <span class="text-red-500">*</span></label>
                        <input type="text" name="location_text" id="location_text" required placeholder="e.g. Brgy. Bagumbayan, Sta. Cruz, Laguna" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition font-bold text-gray-700 dark:text-gray-300">
                    </div>
                    
                    <div class="space-y-2">
                        <label class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">Pin Location on Map <span class="text-red-500">*</span></label>
                        <div id="reportMap" class="h-80 w-full rounded-2xl border-2 border-gray-100 dark:border-slate-700 z-0 dark:brightness-90 dark:contrast-125 dark:hue-rotate-[180deg] dark:invert"></div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest mt-2">Click on the map to set the exact location</p>
                        <input type="hidden" name="lat" id="lat" required>
                        <input type="hidden" name="lng" id="lng" required>
                    </div>
                </div>
            </div>

            <!-- Section 3: Description & Evidence -->
            <div class="space-y-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="w-10 h-10 bg-pnp-blue text-white rounded-xl flex items-center justify-center font-black">3</div>
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white uppercase tracking-tight">Narrative & Evidence</h2>
                </div>

                <div class="space-y-6">
                    <div class="space-y-2">
                        <label for="description" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Detailed Description <span class="text-red-500">*</span></label>
                        <textarea name="description" id="description" rows="6" required placeholder="Describe what happened in detail..." class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition text-gray-700 dark:text-gray-300 leading-relaxed"></textarea>
                    </div>

                    <div class="space-y-2">
                        <label for="photo" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Photo Evidence (Optional)</label>
                        <div class="relative">
                            <input type="file" name="photo" id="photo" accept="image/*" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-black file:bg-pnp-blue file:text-white hover:file:bg-blue-900">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 4: Contact Info -->
            <div class="space-y-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="w-10 h-10 bg-pnp-blue text-white rounded-xl flex items-center justify-center font-black">4</div>
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white uppercase tracking-tight">Contact Information</h2>
                </div>

                <div class="space-y-2">
                    <label for="contact_info" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Your Name & Phone/Email (Optional)</label>
                    <input type="text" name="contact_info" id="contact_info" placeholder="e.g. Juan Dela Cruz - 09123456789" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition font-bold text-gray-700 dark:text-gray-300">
                    <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest mt-2">Providing contact info helps us follow up on your report.</p>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-10 border-t border-gray-100 dark:border-slate-700">
                <button type="submit" class="w-full bg-pnp-blue hover:bg-blue-900 text-white font-black py-6 rounded-2xl shadow-2xl transition duration-300 transform hover:-translate-y-1 flex items-center justify-center space-x-4 uppercase tracking-widest text-sm">
                    <i class="fas fa-paper-plane text-xl"></i>
                    <span>Submit Official Report</span>
                </button>
                <p class="text-center text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest mt-6">
                    By submitting, you confirm that the information provided is true and accurate.
                </p>
            </div>
        </form>
    </div>
</div>

<script>
    const bounds = [[14.24, 121.38], [14.33, 121.46]];
    const map = L.map('reportMap', {
        center: [14.2811, 121.4150],
        zoom: 13,
        minZoom: 12,
        maxZoom: 17,
        maxBounds: bounds,
        maxBoundsViscosity: 1.0,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false,
        zoomControl: false
    });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    let barangayLayer;
    let santaCruzGeoJSON;

    // Load Santa Cruz Barangays GeoJSON for geofencing
    fetch('https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.0.1.json')
        .then(response => response.json())
        .then(data => {
            santaCruzGeoJSON = data;
            barangayLayer = L.geoJSON(data, {
                style: function(feature) {
                    return {
                        fillColor: '#1A3A5C',
                        weight: 2,
                        opacity: 1,
                        color: '#C8A415',
                        fillOpacity: 0.1
                    };
                },
                onEachFeature: function(feature, layer) {
                    layer.bindPopup(`<div class="p-2 font-black uppercase tracking-widest text-xs text-pnp-blue">Brgy. ${feature.properties.NAME_3}</div>`);
                }
            }).addTo(map);
        })
        .catch(err => console.error('Error loading GeoJSON:', err));

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        // vs can be nested if it's a MultiPolygon or has holes
        const x = point[0], y = point[1];
        let inside = false;
        
        // Handle MultiPolygon (array of polygons)
        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        // Handle Polygon with holes (first array is outer ring)
        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    // Main geofence check
    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    document.getElementById('location_text').value = `Brgy. ${feature.properties.NAME_3}, Sta. Cruz, Laguna`;
                    break;
                }
            }
        }
        return isInside;
    }

    let marker;
    map.on('click', function(e) {
        if (santaCruzGeoJSON && !checkGeofence(e.latlng)) {
            alert('Please select a location within Santa Cruz, Laguna.');
            return;
        }

        if (marker) map.removeLayer(marker);
        marker = L.marker(e.latlng).addTo(map);
        document.getElementById('lat').value = e.latlng.lat;
        document.getElementById('lng').value = e.latlng.lng;
    });

    // Auto-set current date/time
    const now = new Date();
    now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    document.getElementById('incident_date').value = now.toISOString().slice(0, 16);
</script>
