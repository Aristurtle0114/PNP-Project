<div class="h-[calc(100vh-160px)] relative z-0">
    <!-- Map Container -->
    <div id="leafletMap" class="h-full w-full transition-all duration-500"></div>

    <!-- Floating Search Bar -->
    <div class="absolute top-8 left-1/2 -translate-x-1/2 z-[1100] w-full max-w-md px-4">
        <div class="relative group">
            <input type="text" id="mapSearchInput" placeholder="Search for a place in Sta. Cruz..." class="w-full pl-14 pr-16 py-5 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md border border-white/30 dark:border-slate-700/30 rounded-[2rem] shadow-2xl text-sm font-bold focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition-all duration-500 text-pnp-blue dark:text-pnp-gold">
            <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-pnp-blue transition text-lg"></i>
            <button onclick="searchLocation()" class="absolute right-3 top-1/2 -translate-y-1/2 bg-pnp-blue text-white w-12 h-12 rounded-2xl hover:bg-blue-900 transition shadow-lg flex items-center justify-center">
                <i class="fas fa-arrow-right"></i>
            </button>
            <p id="searchError" class="absolute -bottom-8 left-6 text-[10px] text-red-500 font-black uppercase hidden bg-white/80 dark:bg-slate-900/80 px-3 py-1 rounded-full backdrop-blur-sm">Location not found. Try again.</p>
        </div>
    </div>
    
    <!-- Loading Overlay -->
    <div id="mapLoading" class="absolute inset-0 bg-pnp-blue z-[1200] flex flex-col items-center justify-center text-white transition-opacity duration-500">
        <div class="w-20 h-20 border-4 border-pnp-gold border-t-transparent rounded-full animate-spin mb-6"></div>
        <p class="text-xs font-black uppercase tracking-[0.3em] animate-pulse">Initializing Secure Map Data...</p>
    </div>

    <!-- Toggle Button (Always Visible on Desktop) -->
    <button id="sidebarToggle" onclick="toggleSidebar()" class="absolute top-8 left-8 z-[1100] w-12 h-12 bg-pnp-blue text-pnp-gold rounded-2xl shadow-2xl hidden md:flex items-center justify-center text-xl hover:bg-pnp-blue/90 transition-all duration-300 group">
        <i class="fas fa-info group-hover:scale-110 transition"></i>
    </button>

    <!-- Floating Filter Panel -->
    <div id="filterSidebar" class="absolute top-8 left-8 z-[1000] w-80 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-[2.5rem] shadow-2xl border border-white/30 dark:border-slate-700/30 overflow-hidden transition-all duration-500 origin-top-left sidebar-hidden">
        <div class="bg-pnp-blue p-8 pr-16 text-white relative">
            <h3 class="text-xs font-black text-pnp-gold uppercase tracking-[0.3em] mb-2">Location Overview</h3>
            <h4 class="text-2xl font-black tracking-tighter">Sta. Cruz Map</h4>
            <!-- Close button inside sidebar for better UX -->
            <button onclick="toggleSidebar()" class="absolute top-8 right-8 text-pnp-gold/50 hover:text-pnp-gold transition">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        
        <div class="p-8 space-y-8">
            <div class="space-y-4">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Filter Incidents</label>
                <div class="space-y-3">
                    <div class="space-y-1">
                        <label class="text-[9px] font-bold text-gray-400 uppercase">Incident Type</label>
                        <select id="filterType" onchange="loadMapPoints()" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 dark:text-white">
                            <option value="">All Types</option>
                            <option value="Theft">Theft</option>
                            <option value="Vandalism">Vandalism</option>
                            <option value="Assault">Assault</option>
                            <option value="Suspicious Activity">Suspicious Activity</option>
                            <option value="Robbery">Robbery</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[9px] font-bold text-gray-400 uppercase">Date Range</label>
                        <select id="filterRange" onchange="loadMapPoints()" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 dark:text-white">
                            <option value="">All Time</option>
                            <option value="7days">Last 7 Days</option>
                            <option value="30days">Last 30 Days</option>
                            <option value="6months">Last 6 Months</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="space-y-4 pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Incident Legend</label>
                <div class="grid grid-cols-2 gap-3">
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#dc2626]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Theft</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#f97316]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Vandalism</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#7f1d1d]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Assault</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#eab308]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Suspicious</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#9333ea]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Robbery</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-[#6b7280]"></span>
                        <span class="text-[9px] font-bold text-gray-600 dark:text-gray-400 uppercase">Other</span>
                    </div>
                </div>
            </div>

            <div class="space-y-4 pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Map Information</label>
                <div class="p-6 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700">
                    <p class="text-xs font-bold text-gray-600 dark:text-gray-400 leading-relaxed">
                        This interactive map provides a real-time overview of the Santa Cruz, Laguna area. Use the search bar above to find specific locations.
                    </p>
                </div>
            </div>

            <div class="space-y-4 pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Geofencing Status</label>
                <div class="flex items-center space-x-3 bg-green-50 dark:bg-green-900/20 p-4 rounded-2xl border border-green-100 dark:border-green-900/30">
                    <div class="relative">
                        <div class="w-3 h-3 bg-green-500 rounded-full animate-ping absolute inset-0"></div>
                        <div class="w-3 h-3 bg-green-500 rounded-full relative"></div>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-green-700 dark:text-green-400 uppercase tracking-widest">Active Monitoring</p>
                        <p class="text-[9px] font-bold text-green-600/70 dark:text-green-500/70 uppercase tracking-tight">Sta. Cruz Perimeter Secured</p>
                    </div>
                </div>
            </div>

            <div class="pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4 block">Map Controls</label>
                <button id="mapInteractionToggle" onclick="toggleMapInteraction()" class="w-full flex items-center justify-between px-6 py-4 bg-pnp-blue text-white rounded-2xl hover:bg-blue-900 transition-all duration-300 shadow-lg group mb-4">
                    <div class="flex items-center space-x-3">
                        <i id="lockIcon" class="fas fa-lock text-pnp-gold group-hover:scale-110 transition"></i>
                        <span id="lockText" class="text-[10px] font-black uppercase tracking-widest">Map Locked</span>
                    </div>
                    <span class="text-[8px] font-bold text-pnp-gold/50 uppercase">Toggle</span>
                </button>
                <p class="text-[9px] text-gray-400 font-bold uppercase text-center mb-6">Unlock to explore the map manually</p>

                <div class="flex items-center space-x-3 text-gray-500 dark:text-gray-400">
                    <i class="fas fa-info-circle text-pnp-gold"></i>
                    <p class="text-[10px] font-bold uppercase tracking-widest leading-relaxed">
                        Data is updated in real-time based on official police reports.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend (Mobile) -->
    <div class="absolute bottom-8 right-8 z-[1000] md:hidden">
        <button onclick="toggleSidebar()" class="w-16 h-16 bg-pnp-blue text-white rounded-2xl shadow-2xl flex items-center justify-center text-2xl">
            <i class="fas fa-info"></i>
        </button>
    </div>
</div>

<script>
    let map;
    let searchMarker;
    let santaCruzGeoJSON;
    let incidentMarkers = L.layerGroup();
    let isMapLocked = true;
    const barangayGeoJsonUrl = 'https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.0.1.json';

    function toggleMapInteraction() {
        if (!map) return;
        
        isMapLocked = !isMapLocked;
        const lockIcon = document.getElementById('lockIcon');
        const lockText = document.getElementById('lockText');
        const toggleBtn = document.getElementById('mapInteractionToggle');

        if (isMapLocked) {
            map.dragging.disable();
            map.touchZoom.disable();
            map.doubleClickZoom.disable();
            map.scrollWheelZoom.disable();
            map.boxZoom.disable();
            map.keyboard.disable();
            if (map.zoomControl) map.zoomControl.remove();
            
            lockIcon.className = 'fas fa-lock text-pnp-gold group-hover:scale-110 transition';
            lockText.textContent = 'Map Locked';
            toggleBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
            toggleBtn.classList.add('bg-pnp-blue', 'hover:bg-blue-900');
        } else {
            map.dragging.enable();
            map.touchZoom.enable();
            map.doubleClickZoom.enable();
            map.scrollWheelZoom.enable();
            map.boxZoom.enable();
            map.keyboard.enable();
            L.control.zoom({ position: 'topright' }).addTo(map);
            
            lockIcon.className = 'fas fa-lock-open text-white group-hover:scale-110 transition';
            lockText.textContent = 'Map Unlocked';
            toggleBtn.classList.remove('bg-pnp-blue', 'hover:bg-blue-900');
            toggleBtn.classList.add('bg-green-600', 'hover:bg-green-700');
        }
    }

    const colors = {
        'Theft': '#dc2626',
        'Vandalism': '#f97316',
        'Assault': '#7f1d1d',
        'Suspicious Activity': '#eab308',
        'Robbery': '#9333ea',
        'Other': '#6b7280'
    };

    function hideLoading() {
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => {
                loading.classList.add('hidden');
            }, 500);
        }
    }

    async function loadMapPoints() {
        const type = document.getElementById('filterType').value;
        const range = document.getElementById('filterRange').value;
        
        try {
            const url = `/api/map-points?type=${type}&range=${range}`;
            const response = await fetch(url);
            const points = await response.json();

            incidentMarkers.clearLayers();

            points.forEach(point => {
                const marker = L.circleMarker([point.lat, point.lng], {
                    radius: 8,
                    fillColor: colors[point.incident_type] || '#6b7280',
                    color: '#FFFFFF',
                    weight: 2,
                    opacity: 1,
                    fillOpacity: 0.8
                });

                marker.bindPopup(`
                    <div class="p-2 min-w-[150px]">
                        <h3 class="text-pnp-blue font-black uppercase tracking-widest text-xs mb-1">${point.incident_type}</h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase mb-2">${new Date(point.incident_date).toLocaleDateString()}</p>
                        <p class="text-[10px] text-gray-700 dark:text-gray-300 font-medium leading-relaxed">
                            ${point.description || 'No additional details provided.'}
                        </p>
                    </div>
                `);

                incidentMarkers.addLayer(marker);
            });

            incidentMarkers.addTo(map);
        } catch (err) {
            console.error('Error loading map points:', err);
        }
    }

    async function searchLocation() {
        if (!map) return;
        
        const input = document.getElementById('mapSearchInput');
        const error = document.getElementById('searchError');
        const button = input.nextElementSibling;
        const icon = button.querySelector('i');
        const query = input.value.trim().toLowerCase();
        
        if (!query) return;

        error.classList.add('hidden');
        button.disabled = true;
        icon.className = 'fas fa-spinner fa-spin';
        
        try {
            // 1. Check for Barangay match in loaded GeoJSON
            if (santaCruzGeoJSON) {
                const cleanQuery = query.replace(/\s+/g, '').replace('brgy.', '').replace('brgy', '').replace('barangay', '');
                
                const barangayMatch = santaCruzGeoJSON.features.find(f => {
                    const name = f.properties.NAME_3.toLowerCase().replace(/\s+/g, '');
                    // Check for exact match or if one contains the other after cleaning
                    return cleanQuery === name || 
                           (cleanQuery.length > 3 && name.includes(cleanQuery)) || 
                           (name.length > 3 && cleanQuery.includes(name));
                });

                if (barangayMatch) {
                    // Use a temporary layer to get the center of the barangay polygon
                    const tempLayer = L.geoJSON(barangayMatch);
                    const center = tempLayer.getBounds().getCenter();
                    
                    if (searchMarker) map.removeLayer(searchMarker);

                    searchMarker = L.marker(center, {
                        icon: L.divIcon({
                            className: 'custom-div-icon',
                            html: `<div class="w-8 h-8 bg-pnp-gold rounded-full border-4 border-white shadow-2xl flex items-center justify-center text-pnp-blue animate-bounce">
                                    <i class="fas fa-location-dot"></i>
                                   </div>`,
                            iconSize: [32, 32],
                            iconAnchor: [16, 32]
                        })
                    }).addTo(map);

                    searchMarker.bindPopup(`
                        <div class="p-2">
                            <p class="text-[10px] font-black text-pnp-blue uppercase tracking-widest mb-1">Barangay Found</p>
                            <p class="text-xs font-bold text-gray-600">Brgy. ${barangayMatch.properties.NAME_3}</p>
                        </div>
                    `).openPopup();

                    map.flyTo(center, 16, {
                        duration: 1.5
                    });
                    
                    // Reset button
                    button.disabled = false;
                    icon.className = 'fas fa-arrow-right';
                    return;
                }
            }

            // 2. Fallback to Nominatim search
            // Restrict search to Santa Cruz, Laguna area using viewbox
            const viewbox = '121.35,14.32,121.48,14.25';
            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query + ', Santa Cruz, Laguna')}&viewbox=${viewbox}&bounded=1&limit=1`;
            
            const response = await fetch(url);
            const data = await response.json();

            if (data && data.length > 0) {
                const result = data[0];
                const lat = parseFloat(result.lat);
                const lon = parseFloat(result.lon);
                const latlng = { lat, lng: lon };

                // Geofence check
                if (santaCruzGeoJSON && !checkGeofence(latlng)) {
                    error.textContent = "Location found but outside Santa Cruz perimeter.";
                    error.classList.remove('hidden');
                    setTimeout(() => {
                        error.classList.add('hidden');
                        error.textContent = "Location not found. Try again.";
                    }, 3000);
                    
                    // Reset button
                    button.disabled = false;
                    icon.className = 'fas fa-arrow-right';
                    return;
                }

                if (searchMarker) map.removeLayer(searchMarker);

                searchMarker = L.marker([lat, lon], {
                    icon: L.divIcon({
                        className: 'custom-div-icon',
                        html: `<div class="w-8 h-8 bg-pnp-gold rounded-full border-4 border-white shadow-2xl flex items-center justify-center text-pnp-blue animate-bounce">
                                <i class="fas fa-location-dot"></i>
                               </div>`,
                        iconSize: [32, 32],
                        iconAnchor: [16, 32]
                    })
                }).addTo(map);

                searchMarker.bindPopup(`
                    <div class="p-2">
                        <p class="text-[10px] font-black text-pnp-blue uppercase tracking-widest mb-1">Search Result</p>
                        <p class="text-xs font-bold text-gray-600">${result.display_name.split(',')[0]}</p>
                    </div>
                `).openPopup();

                map.flyTo([lat, lon], 16, {
                    duration: 1.5
                });
            } else {
                error.classList.remove('hidden');
                setTimeout(() => error.classList.add('hidden'), 3000);
            }
        } catch (err) {
            console.error('Search error:', err);
            error.classList.remove('hidden');
            setTimeout(() => error.classList.add('hidden'), 3000);
        } finally {
            // Reset button
            button.disabled = false;
            icon.className = 'fas fa-arrow-right';
        }
    }

    // Add enter key support for search
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && document.activeElement.id === 'mapSearchInput') {
            searchLocation();
        }
    });

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        const x = point[0], y = point[1];
        let inside = false;
        
        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    break;
                }
            }
        }
        return isInside;
    }

    function initMap() {
        try {
            const center = [14.2811, 121.4150];
            
            map = L.map('leafletMap', {
                center: center,
                zoom: 14,
                zoomControl: false,
                dragging: false,
                touchZoom: false,
                doubleClickZoom: false,
                scrollWheelZoom: false,
                boxZoom: false,
                keyboard: false,
                attributionControl: true
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            // Initialize incident markers layer
            incidentMarkers.addTo(map);
            loadMapPoints();

            // Hide loading as soon as map is initialized
            hideLoading();

            // Load Barangay GeoJSON
            fetch(barangayGeoJsonUrl)
                .then(res => {
                    if (!res.ok) throw new Error('Network response was not ok');
                    return res.json();
                })
                .then(data => {
                    santaCruzGeoJSON = data;
                    L.geoJSON(data, {
                        style: function(feature) {
                            return {
                                fillColor: '#1A3A5C',
                                fillOpacity: 0.1,
                                weight: 2,
                                color: '#C8A415'
                            };
                        },
                        onEachFeature: function(feature, layer) {
                            const name = feature.properties.NAME_3;
                            
                            layer.on({
                                mouseover: function(e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.3,
                                        weight: 3
                                    });
                                },
                                mouseout: function(e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.1,
                                        weight: 2
                                    });
                                }
                            });

                            // Add marker for each barangay
                            try {
                                const centroid = layer.getBounds().getCenter();
                                const marker = L.circleMarker(centroid, {
                                    radius: 6,
                                    fillColor: '#C8A415',
                                    color: '#1A3A5C',
                                    weight: 2,
                                    opacity: 1,
                                    fillOpacity: 1
                                }).addTo(map);

                                marker.bindPopup(`
                                    <div class="p-2 min-w-[150px]">
                                        <h3 class="text-pnp-blue font-black uppercase tracking-widest text-xs mb-1">Brgy. ${name}</h3>
                                        <p class="text-[9px] text-gray-500 font-bold uppercase mb-2">Sta. Cruz, Laguna</p>
                                        <div class="flex justify-between items-center">
                                            <span class="text-[8px] text-gray-400 font-bold uppercase">Status</span>
                                            <span class="px-2 py-0.5 bg-green-100 text-green-600 rounded-full text-[7px] font-black uppercase">Secure</span>
                                        </div>
                                    </div>
                                `);
                            } catch (err) {
                                console.error('Error adding marker for barangay:', name, err);
                            }
                        }
                    }).addTo(map);
                })
                .catch(err => {
                    console.error('Error loading GeoJSON:', err);
                });
        } catch (err) {
            console.error('Error initializing map:', err);
            hideLoading();
        }
    }

    function toggleSidebar() {
        const sidebar = document.getElementById('filterSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        
        if (sidebar.classList.contains('sidebar-hidden')) {
            sidebar.classList.remove('sidebar-hidden');
            sidebar.classList.add('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.add('opacity-0', 'pointer-events-none');
        } else {
            sidebar.classList.add('sidebar-hidden');
            sidebar.classList.remove('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.remove('opacity-0', 'pointer-events-none');
        }
    }

    // Initialize map on load using DOMContentLoaded for better reliability
    document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
    .sidebar-hidden {
        opacity: 0;
        transform: scale(0.9) translateX(-20px);
        pointer-events: none;
    }
    .sidebar-visible {
        opacity: 1;
        transform: scale(1) translateX(0);
        pointer-events: auto;
    }
</style>
