<div class="h-[calc(100vh-160px)] relative z-0">
    <!-- Map Container -->
    <div id="crimeMap" class="h-full w-full transition-all duration-500"></div>

    <!-- Toggle Button (Always Visible on Desktop) -->
    <button id="sidebarToggle" onclick="toggleSidebar()" class="absolute top-8 left-8 z-[1100] w-12 h-12 bg-pnp-blue text-pnp-gold rounded-2xl shadow-2xl hidden md:flex items-center justify-center text-xl hover:bg-pnp-blue/90 transition-all duration-300 group">
        <i class="fas fa-filter group-hover:scale-110 transition"></i>
    </button>

    <!-- Floating Filter Panel -->
    <div id="filterSidebar" class="absolute top-8 left-8 z-[1000] w-80 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-[2.5rem] shadow-2xl border border-white/30 dark:border-slate-700/30 overflow-hidden transition-all duration-500 origin-top-left sidebar-hidden">
        <div class="bg-pnp-blue p-8 pr-16 text-white relative">
            <h3 class="text-xs font-black text-pnp-gold uppercase tracking-[0.3em] mb-2">Crime Statistics</h3>
            <h4 class="text-2xl font-black tracking-tighter">Interactive Map</h4>
            <!-- Close button inside sidebar for better UX -->
            <button onclick="toggleSidebar()" class="absolute top-8 right-8 text-pnp-gold/50 hover:text-pnp-gold transition">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        
        <div class="p-8 space-y-8">
            <div class="space-y-4">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Filter by Type</label>
                <div class="grid grid-cols-1 gap-3">
                    <button onclick="filterMap('All')" class="filter-btn active w-full px-5 py-3 rounded-2xl border border-gray-100 dark:border-slate-700 text-xs font-black uppercase tracking-widest transition duration-300 flex items-center justify-between group">
                        <span>All Incidents</span>
                        <i class="fas fa-layer-group text-[10px] group-hover:scale-110 transition"></i>
                    </button>
                    <button onclick="filterMap('Theft')" class="filter-btn w-full px-5 py-3 rounded-2xl border border-gray-100 dark:border-slate-700 text-xs font-black uppercase tracking-widest transition duration-300 flex items-center justify-between group dark:text-gray-300">
                        <span>Theft</span>
                        <span class="w-2 h-2 rounded-full bg-red-600"></span>
                    </button>
                    <button onclick="filterMap('Vandalism')" class="filter-btn w-full px-5 py-3 rounded-2xl border border-gray-100 dark:border-slate-700 text-xs font-black uppercase tracking-widest transition duration-300 flex items-center justify-between group dark:text-gray-300">
                        <span>Vandalism</span>
                        <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                    </button>
                    <button onclick="filterMap('Assault')" class="filter-btn w-full px-5 py-3 rounded-2xl border border-gray-100 dark:border-slate-700 text-xs font-black uppercase tracking-widest transition duration-300 flex items-center justify-between group dark:text-gray-300">
                        <span>Assault</span>
                        <span class="w-2 h-2 rounded-full bg-red-900"></span>
                    </button>
                    <button onclick="filterMap('Suspicious Activity')" class="filter-btn w-full px-5 py-3 rounded-2xl border border-gray-100 dark:border-slate-700 text-xs font-black uppercase tracking-widest transition duration-300 flex items-center justify-between group dark:text-gray-300">
                        <span>Suspicious</span>
                        <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
                    </button>
                </div>
            </div>

            <div class="space-y-4 pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Focus on Barangay</label>
                <div class="relative group">
                    <select id="barangaySelect" onchange="focusBarangay(this.value)" class="w-full px-5 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl text-xs font-black uppercase tracking-widest outline-none focus:border-pnp-gold transition appearance-none cursor-pointer">
                        <option value="">Select Barangay</option>
                    </select>
                    <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-pnp-gold">
                        <i class="fas fa-chevron-down text-[10px]"></i>
                    </div>
                </div>
            </div>

            <div class="space-y-4 pt-8 border-t border-gray-100 dark:border-slate-700">
                <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Geofencing Status</label>
                <div class="flex items-center space-x-3 bg-green-50 dark:bg-green-900/20 p-4 rounded-2xl border border-green-100 dark:border-green-900/30">
                    <div class="relative">
                        <div class="w-3 h-3 bg-green-500 rounded-full animate-ping absolute inset-0"></div>
                        <div class="w-3 h-3 bg-green-500 rounded-full relative"></div>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-green-700 dark:text-green-400 uppercase tracking-widest">Active Monitoring</p>
                        <p class="text-[9px] font-bold text-green-600/70 dark:text-green-500/70 uppercase tracking-tight">Sta. Cruz Perimeter Secured</p>
                    </div>
                </div>
            </div>

            <div class="pt-8 border-t border-gray-100 dark:border-slate-700">
                <div class="flex items-center space-x-3 text-gray-500 dark:text-gray-400">
                    <i class="fas fa-info-circle text-pnp-gold"></i>
                    <p class="text-[10px] font-bold uppercase tracking-widest leading-relaxed">
                        Data is updated in real-time based on official police reports.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend (Mobile) -->
    <div class="absolute bottom-8 right-8 z-[1000] md:hidden">
        <button onclick="toggleSidebar()" class="w-16 h-16 bg-pnp-blue text-white rounded-2xl shadow-2xl flex items-center justify-center text-2xl">
            <i class="fas fa-filter"></i>
        </button>
    </div>
</div>

<style>
    .filter-btn.active {
        background-color: #1A3A5C;
        color: white;
        border-color: #1A3A5C;
        box-shadow: 0 10px 20px rgba(26, 58, 92, 0.2);
    }
    .filter-btn:not(.active):hover {
        background-color: #f9fafb;
        border-color: #C8A415;
    }
    .dark .filter-btn:not(.active):hover {
        background-color: #1e293b;
        border-color: #C8A415;
    }
    
    /* Map Dark Mode Filter */
    .dark #crimeMap {
        filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%);
    }
    
    /* Leaflet Popup Dark Mode */
    .dark .leaflet-popup-content-wrapper, .dark .leaflet-popup-tip {
        background: #1e293b;
        color: #f1f5f9;
        border: 1px solid #334155;
    }
    .sidebar-hidden {
        opacity: 0;
        transform: scale(0.9) translateX(-20px);
        pointer-events: none;
    }
    .sidebar-visible {
        opacity: 1;
        transform: scale(1) translateX(0);
        pointer-events: auto;
    }
</style>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('filterSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        
        if (sidebar.classList.contains('sidebar-hidden')) {
            sidebar.classList.remove('sidebar-hidden');
            sidebar.classList.add('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.add('opacity-0', 'pointer-events-none');
        } else {
            sidebar.classList.add('sidebar-hidden');
            sidebar.classList.remove('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.remove('opacity-0', 'pointer-events-none');
        }
    }

    const bounds = [[14.24, 121.38], [14.33, 121.46]];
    const map = L.map('crimeMap', {
        center: [14.2811, 121.4150],
        zoom: 13,
        minZoom: 12,
        maxZoom: 17,
        maxBounds: bounds,
        maxBoundsViscosity: 1.0,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false,
        zoomControl: false
    });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    let barangayLayers = {};

    // Load Santa Cruz Barangays GeoJSON
    fetch('https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.0.1.json')
        .then(response => response.json())
        .then(data => {
            const select = document.getElementById('barangaySelect');
            const sortedBarangays = data.features.sort((a, b) => a.properties.NAME_3.localeCompare(b.properties.NAME_3));
            
            sortedBarangays.forEach(feature => {
                const opt = document.createElement('option');
                opt.value = feature.properties.NAME_3;
                opt.innerText = feature.properties.NAME_3;
                select.appendChild(opt);
            });

            L.geoJSON(data, {
                style: function(feature) {
                    return {
                        fillColor: '#1A3A5C',
                        weight: 2,
                        opacity: 1,
                        color: '#C8A415',
                        fillOpacity: 0.1
                    };
                },
                onEachFeature: function(feature, layer) {
                    barangayLayers[feature.properties.NAME_3] = layer;
                    layer.bindPopup(`<div class="p-2 font-black uppercase tracking-widest text-xs text-pnp-blue">Brgy. ${feature.properties.NAME_3}</div>`);
                    layer.on('mouseover', function() {
                        this.setStyle({ fillOpacity: 0.3 });
                    });
                    layer.on('mouseout', function() {
                        if (document.getElementById('barangaySelect').value !== feature.properties.NAME_3) {
                            this.setStyle({ fillOpacity: 0.1 });
                        }
                    });
                }
            }).addTo(map);
        })
        .catch(err => console.error('Error loading GeoJSON:', err));

    function focusBarangay(name) {
        // Reset all styles
        Object.values(barangayLayers).forEach(layer => {
            layer.setStyle({ fillOpacity: 0.1, color: '#C8A415', weight: 2 });
        });

        if (name && barangayLayers[name]) {
            const layer = barangayLayers[name];
            layer.setStyle({ fillOpacity: 0.4, color: '#C8A415', weight: 4 });
            layer.openPopup();
        }
    }

    const colors = {
        'Theft': 'red',
        'Vandalism': 'orange',
        'Assault': 'darkred',
        'Suspicious Activity': 'yellow',
        'Robbery': 'purple',
        'Other': 'gray'
    };

    let markers = [];

    async function fetchPoints() {
        const response = await fetch('/api/map-points');
        const points = await response.json();
        renderPoints(points);
    }

    function renderPoints(points) {
        markers.forEach(m => map.removeLayer(m));
        markers = [];

        points.forEach(p => {
            const marker = L.circleMarker([p.lat, p.lng], {
                radius: 10,
                fillColor: colors[p.incident_type] || 'gray',
                color: '#fff',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map).bindPopup(`
                <div class="p-2">
                    <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">Incident Type</p>
                    <p class="text-sm font-black text-pnp-blue dark:text-pnp-gold mb-2">${p.incident_type}</p>
                    <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">Date Reported</p>
                    <p class="text-xs font-bold text-gray-700 dark:text-gray-300">${new Date(p.incident_date).toLocaleDateString()}</p>
                </div>
            `);
            marker.incident_type = p.incident_type;
            markers.push(marker);
        });
    }

    function filterMap(type) {
        // Update UI
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.classList.remove('active');
            if (btn.innerText.includes(type) || (type === 'All' && btn.innerText.includes('All'))) {
                btn.classList.add('active');
            }
        });

        // Filter Markers
        markers.forEach(m => {
            if (type === 'All' || m.incident_type === type) {
                m.addTo(map);
            } else {
                map.removeLayer(m);
            }
        });
    }

    fetchPoints();
</script>
