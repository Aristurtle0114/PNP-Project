<div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="bg-white dark:bg-slate-800 rounded-[3rem] shadow-2xl p-12 md:p-20 border-t-[12px] border-pnp-gold relative overflow-hidden">
        <!-- Background Decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-pnp-blue/5 dark:bg-pnp-gold/5 -translate-y-1/2 translate-x-1/2 rounded-full"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-pnp-gold/5 dark:bg-pnp-blue/5 translate-y-1/2 -translate-x-1/2 rounded-full"></div>

        <div class="relative z-10">
            <div class="w-24 h-24 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-3xl flex items-center justify-center mx-auto mb-10 shadow-lg group hover:scale-110 transition duration-500">
                <i class="fas fa-check-double text-4xl"></i>
            </div>
            
            <h1 class="text-4xl font-black text-pnp-blue dark:text-pnp-gold mb-4 tracking-tighter">Report Submitted Successfully</h1>
            <p class="text-gray-500 dark:text-gray-400 mb-12 text-lg leading-relaxed">Your incident report has been officially recorded. Please save your tracking number for future reference and follow-up.</p>
            
            <div class="bg-pnp-blue dark:bg-slate-900 text-white rounded-[2.5rem] p-10 mb-12 shadow-2xl relative group">
                <p class="text-[10px] text-blue-300 dark:text-gray-500 uppercase tracking-[0.3em] font-black mb-4">Official Tracking Number</p>
                <p class="text-4xl md:text-5xl font-black tracking-tighter text-pnp-gold" id="trackingNum"><%= tracking_number %></p>
                
                <button onclick="copyTracking()" class="mt-6 text-[10px] font-black uppercase tracking-widest text-white/50 hover:text-white transition flex items-center justify-center space-x-2 mx-auto">
                    <i class="far fa-copy"></i>
                    <span id="copyText">Copy to Clipboard</span>
                </button>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a href="/track" class="bg-pnp-gold hover:bg-yellow-600 text-pnp-blue font-black py-5 px-8 rounded-2xl shadow-xl transition duration-300 uppercase tracking-widest text-xs">
                    Track Status Now
                </a>
                <a href="/" class="bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 text-gray-800 dark:text-gray-200 font-black py-5 px-8 rounded-2xl transition duration-300 uppercase tracking-widest text-xs">
                    Return to Home
                </a>
            </div>
            
            <p class="mt-12 text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest leading-relaxed">
                "Your contribution helps us build a safer community. <br> Thank you for your cooperation."
            </p>
        </div>
    </div>
</div>

<script>
    function copyTracking() {
        const text = document.getElementById('trackingNum').innerText;
        navigator.clipboard.writeText(text).then(() => {
            const copyText = document.getElementById('copyText');
            copyText.innerText = 'Copied!';
            setTimeout(() => {
                copyText.innerText = 'Copy to Clipboard';
            }, 2000);
        });
    }
</script>
