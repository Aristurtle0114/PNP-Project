<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
    <!-- Filters -->
    <div class="p-6 border-b border-gray-50 dark:border-slate-700 flex flex-wrap gap-4 items-center justify-between">
        <form action="/admin/reports" method="GET" class="flex flex-wrap gap-4">
            <select name="status" class="px-4 py-2 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-bold uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue outline-none text-gray-700 dark:text-gray-300">
                <option value="">All Statuses</option>
                <option value="Received" <%= status === 'Received' ? 'selected' : '' %>>Received</option>
                <option value="Under Review" <%= status === 'Under Review' ? 'selected' : '' %>>Under Review</option>
                <option value="Resolved" <%= status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                <option value="Closed" <%= status === 'Closed' ? 'selected' : '' %>>Closed</option>
            </select>
            <select name="type" class="px-4 py-2 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-bold uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue outline-none text-gray-700 dark:text-gray-300">
                <option value="">All Types</option>
                <option value="Theft" <%= type === 'Theft' ? 'selected' : '' %>>Theft</option>
                <option value="Vandalism" <%= type === 'Vandalism' ? 'selected' : '' %>>Vandalism</option>
                <option value="Assault" <%= type === 'Assault' ? 'selected' : '' %>>Assault</option>
                <option value="Suspicious Activity" <%= type === 'Suspicious Activity' ? 'selected' : '' %>>Suspicious Activity</option>
                <option value="Robbery" <%= type === 'Robbery' ? 'selected' : '' %>>Robbery</option>
                <option value="Other" <%= type === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
            <button type="submit" class="bg-pnp-blue text-white px-6 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-blue-900 transition">Filter</button>
            <a href="/admin/reports" class="bg-gray-100 dark:bg-slate-700 text-gray-500 dark:text-gray-400 px-6 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-gray-200 dark:hover:bg-slate-600 transition">Reset</a>
        </form>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 dark:text-gray-500 uppercase text-[10px] font-bold tracking-widest">
                <tr>
                    <th class="px-6 py-4">Tracking No.</th>
                    <th class="px-6 py-4">Type</th>
                    <th class="px-6 py-4">Date Filed</th>
                    <th class="px-6 py-4">Location</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                <% reports.forEach(report => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition">
                        <td class="px-6 py-4 font-mono font-bold text-pnp-blue dark:text-pnp-gold"><%= report.tracking_number %></td>
                        <td class="px-6 py-4 font-medium text-gray-700 dark:text-gray-300"><%= report.type %></td>
                        <td class="px-6 py-4 text-gray-400 dark:text-gray-500 text-xs"><%= new Date(report.created_at).toLocaleDateString() %></td>
                        <td class="px-6 py-4 text-gray-500 dark:text-gray-400 max-w-xs truncate"><%= report.location_text %></td>
                        <td class="px-6 py-4">
                            <% 
                                const statusColors = {
                                    'Received': 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400',
                                    'Under Review': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400',
                                    'Resolved': 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400',
                                    'Closed': 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
                                };
                            %>
                            <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= statusColors[report.status] %>">
                                <%= report.status %>
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <a href="/admin/reports/<%= report.id %>" class="text-pnp-blue dark:text-pnp-gold hover:text-pnp-gold dark:hover:text-white font-bold text-xs uppercase tracking-widest">View Details</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="p-6 bg-gray-50 dark:bg-slate-900/50 border-t border-gray-100 dark:border-slate-700 flex justify-center space-x-2">
        <% if (page > 1) { %>
            <a href="/admin/reports?page=<%= page - 1 %><%= status ? '&status=' + status : '' %><%= type ? '&type=' + type : '' %>" class="px-4 py-2 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-bold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-slate-700 transition">Previous</a>
        <% } %>
        <span class="px-4 py-2 bg-pnp-blue text-white rounded-lg text-xs font-bold">Page <%= page %></span>
        <% if (reports.length === 10) { %>
            <a href="/admin/reports?page=<%= page + 1 %><%= status ? '&status=' + status : '' %><%= type ? '&type=' + type : '' %>" class="px-4 py-2 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-bold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-slate-700 transition">Next</a>
        <% } %>
    </div>
</div>
