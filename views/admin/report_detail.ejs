<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Report Info -->
    <div class="lg:col-span-2 space-y-8">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Incident Details</h3>
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= 
                    report.status === 'Received' ? 'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400' : 
                    report.status === 'Under Review' ? 'bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400' : 
                    report.status === 'Resolved' ? 'bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-600 dark:bg-slate-700 dark:text-gray-400' 
                %>">
                    <%= report.status %>
                </span>
            </div>
            <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Tracking Number</p>
                        <p class="text-xl font-mono font-bold text-pnp-blue dark:text-pnp-gold"><%= report.tracking_number %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Incident Type</p>
                        <p class="text-lg font-bold text-gray-800 dark:text-white"><%= report.type %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Incident Date & Time</p>
                        <p class="text-gray-700 dark:text-gray-300 font-medium"><%= new Date(report.incident_date).toLocaleString() %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Location Address</p>
                        <p class="text-gray-700 dark:text-gray-300 font-medium"><%= report.location_text %></p>
                    </div>
                </div>
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Contact Information</p>
                        <p class="text-gray-700 dark:text-gray-300 font-medium"><%= report.contact_info || 'Not Provided' %></p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-1">Date Filed</p>
                        <p class="text-gray-700 dark:text-gray-300 font-medium"><%= new Date(report.created_at).toLocaleString() %></p>
                    </div>
                </div>
                <div class="md:col-span-2">
                    <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold mb-2">Description</p>
                    <div class="bg-gray-50 dark:bg-slate-900 p-6 rounded-xl border border-gray-100 dark:border-slate-700 text-gray-700 dark:text-gray-300 leading-relaxed text-sm">
                        <%= report.description %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Location -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Pinned Location</h3>
            </div>
            <div id="leafletMap" class="h-96 w-full z-0"></div>
        </div>
    </div>

    <!-- Sidebar Actions -->
    <div class="space-y-8">
        <!-- Status Update -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Update Status</h3>
            </div>
            <form action="/admin/reports/<%= report.id %>/update" method="POST" class="p-8 space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Current Status</label>
                    <select name="status" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                        <option value="Received" <%= report.status === 'Received' ? 'selected' : '' %>>Received</option>
                        <option value="Under Review" <%= report.status === 'Under Review' ? 'selected' : '' %>>Under Review</option>
                        <option value="Resolved" <%= report.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                        <option value="Closed" <%= report.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Internal Notes (Admin Only)</label>
                    <textarea name="internal_notes" rows="4" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm dark:text-white" placeholder="Add notes about the investigation..."><%= report.internal_notes %></textarea>
                </div>
                <button type="submit" class="w-full bg-pnp-blue text-white font-bold py-3 rounded-lg text-xs uppercase tracking-widest hover:bg-blue-900 transition shadow-lg">Save Changes</button>
            </form>
        </div>

        <!-- Photo Preview -->
        <% if (report.photo_path) { %>
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
                <div class="p-8 border-b border-gray-50 dark:border-slate-700">
                    <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Photo Evidence</h3>
                </div>
                <div class="p-4">
                    <img src="<%= report.photo_path %>" alt="Evidence" class="w-full rounded-xl shadow-md">
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    function initMap() {
        try {
            const reportLocation = [<%= report.lat %>, <%= report.lng %>];
            const map = L.map('leafletMap', {
                center: reportLocation,
                zoom: 16,
                zoomControl: false,
                dragging: false,
                touchZoom: false,
                doubleClickZoom: false,
                scrollWheelZoom: false,
                boxZoom: false,
                keyboard: false,
                attributionControl: false
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            L.marker(reportLocation).addTo(map)
                .bindPopup("Incident Location")
                .openPopup();
        } catch (err) {
            console.error('Error initializing report detail map:', err);
        }
    }

    // Initialize map on load using DOMContentLoaded for better reliability
    document.addEventListener('DOMContentLoaded', initMap);
</script>

