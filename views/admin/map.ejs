<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 h-[calc(100vh-160px)]">
    <!-- Map Area -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden relative z-0">
        <!-- Map Search -->
        <div class="absolute top-4 left-4 right-4 md:right-auto md:w-80 z-[1000]">
            <div class="relative group">
                <input type="text" id="mapSearchInput" placeholder="Search location in Sta. Cruz..." class="w-full pl-10 pr-4 py-3 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-4 focus:ring-pnp-blue/10 focus:border-pnp-blue outline-none transition-all duration-300 shadow-2xl dark:text-white">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-pnp-blue transition"></i>
                <button type="button" onclick="searchLocation()" class="absolute right-2 top-1/2 -translate-y-1/2 bg-pnp-blue text-white px-3 py-1.5 rounded-lg hover:bg-blue-900 transition text-[10px] font-black uppercase tracking-widest">
                    Go
                </button>
            </div>
            <p id="searchError" class="mt-2 px-3 py-1 bg-red-500 text-white text-[9px] font-black uppercase rounded-lg hidden shadow-lg">Location not found in Sta. Cruz</p>
        </div>

        <div id="leafletMap" class="h-full w-full"></div>
        <div class="absolute bottom-4 right-4 bg-white dark:bg-slate-800 p-4 rounded-xl shadow-2xl border border-gray-100 dark:border-slate-700 z-[1000] text-xs font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest">
            <i class="fas fa-info-circle mr-2 text-pnp-gold"></i>
            Click map to add new point
        </div>
    </div>

    <!-- Sidebar: Add Point Form -->
    <div class="space-y-8 overflow-y-auto pr-2">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Add Map Point</h3>
            </div>
            <form action="/admin/map/add" method="POST" class="p-6 space-y-6" id="addPointForm">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Latitude</label>
                        <input type="text" name="lat" id="lat" required readonly class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-mono dark:text-white">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Longitude</label>
                        <input type="text" name="lng" id="lng" required readonly class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg text-xs font-mono dark:text-white">
                    </div>
                </div>
                
                <div class="space-y-2">
                    <label for="incident_type" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Incident Type</label>
                    <select name="incident_type" id="incident_type" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                        <option value="Theft">Theft</option>
                        <option value="Vandalism">Vandalism</option>
                        <option value="Assault">Assault</option>
                        <option value="Suspicious Activity">Suspicious Activity</option>
                        <option value="Robbery">Robbery</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="space-y-2">
                    <label for="incident_date" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Incident Date</label>
                    <input type="date" name="incident_date" id="incident_date" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>

                <button type="submit" class="w-full bg-pnp-blue text-white font-bold py-4 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
                    Add Point to Map
                </button>
            </form>
        </div>

        <!-- Legend -->
        <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700">
            <h4 class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4">Color Codes</h4>
            <div class="space-y-3">
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-red-600"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Theft</span>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-orange-500"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Vandalism</span>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-red-900"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Assault</span>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Suspicious Activity</span>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-purple-600"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Robbery</span>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="w-3 h-3 rounded-full bg-gray-500"></span>
                    <span class="text-xs text-gray-600 dark:text-gray-400 font-bold">Other</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let map;
    let tempMarker;
    let santaCruzGeoJSON;
    const barangayGeoJsonUrl = 'https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.0.1.json';
    const colors = {
        'Theft': '#dc2626',
        'Vandalism': '#f97316',
        'Assault': '#7f1d1d',
        'Suspicious Activity': '#eab308',
        'Robbery': '#9333ea',
        'Other': '#6b7280'
    };

    function initMap() {
        try {
            const center = [14.2811, 121.4150];
            map = L.map('leafletMap', {
                center: center,
                zoom: 14,
                zoomControl: false,
                dragging: false,
                touchZoom: false,
                doubleClickZoom: false,
                scrollWheelZoom: false,
                boxZoom: false,
                keyboard: false,
                attributionControl: false
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            // Load GeoJSON for geofencing
            fetch(barangayGeoJsonUrl)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.json();
                })
                .then(data => {
                    santaCruzGeoJSON = data;
                    L.geoJSON(data, {
                        style: {
                            fillColor: '#1A3A5C',
                            fillOpacity: 0.05,
                            weight: 1,
                            color: '#C8A415'
                        }
                    }).addTo(map);
                })
                .catch(err => console.error('Error loading GeoJSON for geofencing:', err));

            // Render Existing Points
            <% points.forEach(p => { %>
                L.circle([<%= p.lat %>, <%= p.lng %>], {
                    color: '#FFFFFF',
                    fillColor: colors['<%= p.incident_type %>'] || '#6b7280',
                    fillOpacity: 0.8,
                    radius: 50,
                    weight: 2
                }).addTo(map);
            <% }) %>

            map.on('click', (e) => {
                const latlng = e.latlng;
                setMarker(latlng);
            });
        } catch (err) {
            console.error('Error initializing admin map:', err);
        }
    }

    function setMarker(latlng) {
        if (santaCruzGeoJSON && !checkGeofence(latlng)) {
            alert('Please select a location within Santa Cruz, Laguna.');
            return false;
        }

        if (tempMarker) map.removeLayer(tempMarker);
        tempMarker = L.marker(latlng).addTo(map);

        document.getElementById('lat').value = latlng.lat.toFixed(6);
        document.getElementById('lng').value = latlng.lng.toFixed(6);
        return true;
    }

    async function searchLocation() {
        const input = document.getElementById('mapSearchInput');
        const error = document.getElementById('searchError');
        const query = input.value.trim();
        
        if (!query) return;

        error.classList.add('hidden');
        
        try {
            // Viewbox for Sta. Cruz, Laguna
            const viewbox = '121.35,14.32,121.48,14.25';
            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query + ', Santa Cruz, Laguna')}&viewbox=${viewbox}&bounded=1&limit=1`;
            
            const response = await fetch(url);
            const data = await response.json();

            if (data && data.length > 0) {
                const result = data[0];
                const latlng = L.latLng(parseFloat(result.lat), parseFloat(result.lon));

                if (setMarker(latlng)) {
                    map.flyTo(latlng, 16, { duration: 1.5 });
                } else {
                    error.textContent = "Location found but outside Santa Cruz perimeter.";
                    error.classList.remove('hidden');
                    setTimeout(() => {
                        error.classList.add('hidden');
                        error.textContent = "Location not found in Sta. Cruz";
                    }, 3000);
                }
            } else {
                error.classList.remove('hidden');
                setTimeout(() => error.classList.add('hidden'), 3000);
            }
        } catch (err) {
            console.error('Search error:', err);
            error.classList.remove('hidden');
            setTimeout(() => error.classList.add('hidden'), 3000);
        }
    }

    // Add enter key support for search
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && document.activeElement.id === 'mapSearchInput') {
            e.preventDefault();
            searchLocation();
        }
    });

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        const x = point[0], y = point[1];
        let inside = false;
        
        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    break;
                }
            }
        }
        return isInside;
    }

    // Initialize map on load using DOMContentLoaded for better reliability
    document.addEventListener('DOMContentLoaded', initMap);
</script>

